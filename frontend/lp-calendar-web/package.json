{
  "name": "lp-calendar-web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "generate": "openapi-generator-cli generate -i ../../openapi.yaml -g typescript-angular -o src/app/modules/lpshows-api --additional-properties fileNaming=kebab-case,withInterfaces=true,modelSuffix=Dto --generate-alias-as-model",
    "start": "npm run generate && ng serve",
    "build": "npm run generate && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "npm run generate && ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.7",
